# Bu dosyayı '.env' olarak kopyalayıp değerleri doldur.
# .env dosyası .gitignore'da olduğu için repoya GİRMEZ (güvenli).
#
# Supabase Dashboard -> Project Settings -> API bölümünden al:
#   Project URL           -> SUPABASE_URL
#   service_role (secret)  -> SUPABASE_SERVICE_ROLE_KEY   (anon DEĞİL!)

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=buraya_service_role_anahtarini_yapistir
